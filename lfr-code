}

void handleAction() {
  if (server.hasArg("cmd")) {
    String cmd = server.arg("cmd");
    if      (cmd == "auto")  { currentMode = "AUTO";    stopState = 0; }
    else if (cmd == "stop")  currentMode = "STOPPED";
    else if (cmd == "fwd")   currentMode = "FWD";
    else if (cmd == "bwd")   currentMode = "BWD";
    else if (cmd == "left")  currentMode = "LEFT";
    else if (cmd == "right") currentMode = "RIGHT";
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

// ================================================
//  SETUP
// ================================================
void setup() {
  Serial.begin(115200);

  pinMode(ENA, OUTPUT); pinMode(IN1, OUTPUT); pinMode(IN2, OUTPUT);
  pinMode(ENB, OUTPUT); pinMode(IN3, OUTPUT); pinMode(IN4, OUTPUT);
  for (int i = 0; i < numSensors; i++) pinMode(sensorPins[i], INPUT);
  pinMode(PIR_PIN, INPUT);
  pinMode(SOUND_PIN, INPUT);

  // WiFi
  IPAddress localIP(192, 168, 151, 100);
  IPAddress gateway(192, 168, 151, 1);
  IPAddress subnet(255, 255, 255, 0);
  WiFi.config(localIP, gateway, subnet);

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi...");
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    delay(500); Serial.print("."); attempts++;
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nConnected! IP: " + WiFi.localIP().toString());
    server.on("/", handleRoot);
    server.on("/action", handleAction);
    server.begin();
  } else {
    Serial.println("\nWiFi failed. Running offline.");
  }

  // ESP-NOW
  esp_now_init();
  esp_now_register_recv_cb(onReply);
  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, receiverMAC, 6);
  peerInfo.channel = 0;
  peerInfo.encrypt = false;
  esp_now_add_peer(&peerInfo);
}

// ================================================
//  SENSOR & PID
// ================================================
int countActiveSensors() {
  int count = 0;
  for (int i = 0; i < numSensors; i++) {
    if (digitalRead(sensorPins[i]) == 1) count++;
  }
  return count;
}

int calculateError() {
  int sum = 0, active = 0;
  for (int i = 0; i < numSensors; i++) {
    if (digitalRead(sensorPins[i]) == 1) {
      sum += weights[i];
      active++;
    }
  }
  if (active == 0) return lastError > 0 ? 4 : -4;
  return sum / active;
}

// ================================================
//  MOTOR CONTROL
// ================================================
void setMotors(int leftSpeed, int rightSpeed) {
  if (leftSpeed >= 0) { digitalWrite(IN1, HIGH); digitalWrite(IN2, LOW); }
  else                { digitalWrite(IN1, LOW);  digitalWrite(IN2, HIGH); }
  analogWrite(ENA, abs(leftSpeed));

  if (rightSpeed >= 0) { digitalWrite(IN3, HIGH); digitalWrite(IN4, LOW); }
  else                 { digitalWrite(IN3, LOW);  digitalWrite(IN4, HIGH); }
  analogWrite(ENB, abs(rightSpeed));
}

// ================================================
//  MAIN LOOP
// ================================================
void loop() {
  if (WiFi.status() == WL_CONNECTED) server.handleClient();

  // ===== INTERSECTION STOP LOGIC =====
  if (currentMode == "AUTO") {
    int activeSensors = countActiveSensors();

    if (stopState == 0 && activeSensors >= 6) {
      stopState = 1;
      stopStateStart = millis();
    }

    if (stopState == 1 && millis() - stopStateStart >= 100) {
      stopState = 2;
      stopStateStart = millis();
      setMotors(0, 0);
      currentLeftSpeed = 0; currentRightSpeed = 0;
    }

    if (stopState == 2) {
      setMotors(0, 0);
      currentLeftSpeed = 0; currentRightSpeed = 0;
      if (millis() - stopStateStart >= 5000) stopState = 0;

      if (millis() - lastPrintTime > 300) {
        int pirVal   = digitalRead(PIR_PIN);
        int soundVal = digitalRead(SOUND_PIN);
        Serial.print("INTERSECTION STOP | PIR: ");
        Serial.print(pirVal == HIGH ? "HUMAN DETECTED" : "no detection");
        Serial.print(" | SOUND: ");
        Serial.println(soundVal == HIGH ? "DETECTED" : "none");

        Message msg;
        msg.pirValue   = pirVal;
        msg.soundValue = soundVal;
        esp_now_send(receiverMAC, (uint8_t *)&msg, sizeof(msg));
        lastPrintTime = millis();
      }
      return;
    }
  }

  // ===== MODE HANDLING =====
  if (currentMode == "AUTO") {
    int error = calculateError();
    integral += error;
    integral = constrain(integral, -INTEGRAL_CLAMP, INTEGRAL_CLAMP);
    float derivative = error - lastError;
    int correction   = (int)((Kp * error) + (Ki * integral) + (Kd * derivative));
    lastError = error;

    int leftSpeed  = constrain(baseSpeed + correction, minSpeed, maxSpeed);
    int rightSpeed = constrain(baseSpeed - correction, minSpeed, maxSpeed);
    currentLeftSpeed  = leftSpeed;
    currentRightSpeed = rightSpeed;
    setMotors(leftSpeed, rightSpeed);

  } else if (currentMode == "STOPPED") {
    setMotors(0, 0);
    currentLeftSpeed = 0; currentRightSpeed = 0;

  } else if (currentMode == "FWD") {
    setMotors(baseSpeed, baseSpeed);
    currentLeftSpeed = baseSpeed; currentRightSpeed = baseSpeed;

  } else if (currentMode == "BWD") {
    setMotors(-baseSpeed, -baseSpeed);
    currentLeftSpeed = -baseSpeed; currentRightSpeed = -baseSpeed;

  } else if (currentMode == "LEFT") {
    setMotors(-baseSpeed, baseSpeed);
    currentLeftSpeed = -baseSpeed; currentRightSpeed = baseSpeed;

  } else if (currentMode == "RIGHT") {
    setMotors(baseSpeed, -baseSpeed);
    currentLeftSpeed = baseSpeed; currentRightSpeed = -baseSpeed;
  }

  if (millis() - lastPrintTime > 300) {
    Serial.print("Mode: "); Serial.print(currentMode);
    Serial.print(" | L: "); Serial.print(currentLeftSpeed);
    Serial.print(" | R: "); Serial.println(currentRightSpeed);
    lastPrintTime = millis();
  }
}
