#include <WiFi.h>
#include <WebServer.h>
#include <esp_now.h>

// ================= WIFI =================
const char* ssid     = "net";
const char* password = "take1234";
WebServer server(80);

// ================= ESP-NOW =================
uint8_t receiverMAC[] = {0x70, 0x4B, 0xCA, 0x8E, 0xEF, 0x08};

typedef struct {
  int pirValue;
  int soundValue;
} Message;

typedef struct {
  int ledOff;
} Reply;

extern int stopState;

void onReply(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  Reply reply;
  memcpy(&reply, data, sizeof(reply));
  if (reply.ledOff == 1 && stopState == 2) {
    stopState = 0;
    Serial.println("LED is off — resuming early");
  }
}

// ================= PIR =================
#define PIR_PIN 4

// ================= SOUND =================
#define SOUND_PIN 15

// ================= MOTOR PINS =================
#define ENA 18
#define IN1 5
#define IN2 19
#define ENB 23
#define IN3 21
#define IN4 22

// ================= SENSOR PINS =================
const int numSensors = 8;
const int sensorPins[numSensors] = {32, 33, 25, 26, 27, 14, 12, 13};
const int weights[8] = {-4, -3, -2, -1, 1, 2, 3, 4};

// ================= PID =================
float Kp = 100.0;
float Ki = 0.0;
float Kd = 25.0;
float integral  = 0;
int   lastError = 0;
#define INTEGRAL_CLAMP 150

// ================= SPEED =================
const int baseSpeed = 170;
const int maxSpeed  = 255;
const int minSpeed  = 0;

// ================= STATE =================
String currentMode    = "STOPPED";
int currentLeftSpeed  = 0;
int currentRightSpeed = 0;
unsigned long lastPrintTime = 0;

// ================= STOP LOGIC =================
int stopState = 0;
unsigned long stopStateStart = 0;

// ================================================
//  WEB SERVER
// ================================================
